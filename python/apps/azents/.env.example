# Azents 환경 변수 예시
# 이 파일을 .env로 복사하여 사용하세요

# Runtime environment (local, deployed)
AZ_RUNTIME_ENV=local

# Sentry DSN (optional, for error tracking)
# AZ_SENTRY_DSN=

# PostgreSQL 설정
# 로컬 개발 시 docker compose -f docker-compose.azents.yaml up -d
AZ_RDB_HOST=localhost
AZ_RDB_PORT=5433
AZ_RDB_USER=azents
AZ_RDB_PASSWORD=azents
AZ_RDB_DB_NAME=azents

# AWS RDS IAM 인증 (production용, 로컬에서는 False)
AZ_RDB_USE_IAM_AUTH=False
# AZ_RDB_REGION=us-west-2
# AZ_RDB_SSL_MODE=require

# JWT Secret (개발용, production에서는 안전한 키 사용)
AZ_AUTH_JWT_SECRET_KEY=dev-secret-key-change-in-production

# LLM 자격 증명 암호화 키 (Fernet key, base64 인코딩된 32바이트)
# 생성: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AZ_CREDENTIAL_ENCRYPTION_KEY=bfIsUUPaUYXEygZKaJgJPXc5VJylRYqqI5zc8REYLtY=

# Session data S3 storage (RustFS)
# docker compose -f docker-compose.azents.yaml up -d 로 RustFS 실행 필요
AZ_WORKSPACE_S3_BUCKET=azents-dev
AZ_WORKSPACE_S3_ENDPOINT_URL=http://localhost:9000

# Sandbox - File Gateway sidecar (기본값: azents-file-gateway:local, 비활성화하려면 빈 값으로 설정)
# sandbox 생성 시 file-gateway 이미지를 자동 빌드하여 sidecar로 실행합니다
# AZ_SANDBOX_FILE_GATEWAY_IMAGE=azents-file-gateway:local
AZ_SANDBOX_FILE_GATEWAY_STORAGE_BACKEND=s3
AZ_SANDBOX_FILE_GATEWAY_S3_BUCKET=azents-dev
AZ_SANDBOX_FILE_GATEWAY_S3_ENDPOINT_URL=http://host.docker.internal:9000

# 프론트엔드 URL (OAuth redirect 등)
AZ_WEB_URL=https://localhost:3003

# API 서버 public URL (OAuth redirect 콜백용)
AZ_API_URL=http://localhost:8000

# Redis (Valkey) 설정
AZ_REDIS_URL=redis://localhost:6379

# GitHub Platform App (JWT — Installation Access Token 교환용)
AZ_GITHUB_PLATFORM_APP_ID=
AZ_GITHUB_PLATFORM_PRIVATE_KEY=

# GitHub Platform App (OAuth — Installation 목록 조회용)
AZ_GITHUB_PLATFORM_CLIENT_ID=
AZ_GITHUB_PLATFORM_CLIENT_SECRET=

# Sandbox control (local devserver)
AZ_AGENT_HOME_SANDBOX_CONTROL_ENDPOINT=localhost:8020
AZ_AGENT_HOME_SANDBOX_CONTROL_AUTH_SECRET=dev-sandbox-control-auth-secret
AZ_SANDBOX_CONTROL_PORT=8020
AZ_SANDBOX_CONTROL_INSTANCE_ID=azents-devserver-local
AZ_SANDBOX_CONTROL_AUTH_SECRET=dev-sandbox-control-auth-secret

# Per-session sandbox lifecycle TTL (Phase 5)
# - hibernate idle: 마지막 activity 이후 이 만큼 조용하면 container hibernate (기본 1800 = 30분)
# - snapshot TTL: hibernate 후 이 만큼 경과하면 snapshot 삭제 (기본 86400 = 1일)
# - EFS TTL: expired 이후 이 만큼 경과하면 /home/sandbox EFS subPath 도 삭제 (기본 2592000 = 30일)
# AZ_AZENTS_SESSION_HIBERNATE_IDLE_SECONDS=1800
# AZ_AZENTS_SESSION_SNAPSHOT_TTL_SECONDS=86400
# AZ_AZENTS_SESSION_EFS_TTL_SECONDS=2592000
