# testenv/azents local environment example.
# Copy this file and edit local-only values:
#   cp testenv/azents/.env.example testenv/azents/.env

AZ_RUNTIME_ENV=local
AZ_WEB_URL=http://127.0.0.1:3003
AZ_API_URL=http://127.0.0.1:8010
AZ_PUBLIC_API_PORT=8010
AZ_ADMIN_API_PORT=8011

# PostgreSQL (docker-compose.azents.yaml)
AZ_RDB_HOST=localhost
AZ_RDB_PORT=5433
AZ_RDB_USER=azents
AZ_RDB_PASSWORD=azents
AZ_RDB_DB_NAME=azents
AZ_RDB_USE_IAM_AUTH=False

# Auth / credential encryption (local only)
AZ_AUTH_JWT_SECRET_KEY=dev-secret-key-change-in-production
# Generate a new local key with:
#   python -c "import base64,os;print(base64.b64encode(os.urandom(32)).decode())"
AZ_CREDENTIAL_ENCRYPTION_KEY=bfIsUUPaUYXEygZKaJgJPXc5VJylRYqqI5zc8REYLtY=

# Valkey
AZ_REDIS_URL=redis://localhost:6379/0

# Workspace S3 (RustFS)
AZ_WORKSPACE_S3_BUCKET=azents-dev
AZ_WORKSPACE_S3_ENDPOINT_URL=http://localhost:9000
AZ_WORKSPACE_S3_ACCESS_KEY_ID=dummyaccess
AZ_WORKSPACE_S3_SECRET_ACCESS_KEY=dummysecret

# Testenv-only flags. Production startup must reject these when enabled there.
AZ_TESTENV_API_ENABLED=1
AZ_TESTENV_RUNTIME_HOOK_QA_ENABLED=1

# Optional local tunnel URL for Slack/Discord live checks.
# TESTENV_AZENTS_FUNNEL_URL=https://azents-testenv.example.ts.net

# Optional Slack/Discord local live checks. Do not commit real secrets.
# AZ_SLACK_CLIENT_ID=
# AZ_SLACK_CLIENT_SECRET=
# AZ_SLACK_SIGNING_SECRET=
# AZ_SLACK_APP_TOKEN=
# AZ_DISCORD_BOT_TOKEN=
# AZ_DISCORD_CLIENT_ID=
# AZ_DISCORD_CLIENT_SECRET=
# AZ_DISCORD_PUBLIC_KEY=
# AZ_DISCORD_GATEWAY_SECRET=
