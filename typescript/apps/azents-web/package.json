{
  "name": "@azents/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3003",
    "build": "next build",
    "start": "next start",
    "storybook": "STORYBOOK_DISABLE_TELEMETRY=1 storybook dev -p 6006",
    "build-storybook": "STORYBOOK_DISABLE_TELEMETRY=1 storybook build",
    "lint": "eslint src .storybook --max-warnings 0 --cache --cache-strategy content",
    "lint:fix": "eslint src .storybook --max-warnings 0 --fix --cache --cache-strategy content",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write --cache 'src/**/*.{ts,tsx}' '.storybook/**/*.{ts,tsx}'",
    "format:check": "prettier --check --cache 'src/**/*.{ts,tsx}' '.storybook/**/*.{ts,tsx}'"
  },
  "dependencies": {
    "@azents/public-client": "workspace:*",
    "@mantine/core": "^9.0.0",
    "@mantine/form": "^9.0.0",
    "@mantine/hooks": "^9.0.0",
    "@mantine/modals": "^9.0.0",
    "@sentry/nextjs": "^10.46.0",
    "@tabler/icons-react": "^3.36.1",
    "@tanstack/react-query": "^5.90.12",
    "@trpc/client": "^11.8.1",
    "@trpc/react-query": "^11.8.1",
    "@trpc/server": "^11.8.1",
    "geist": "^1.7.0",
    "mermaid": "^11.16.0",
    "next": "^16.0.10",
    "next-intl": "^4.8.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "superjson": "^2.2.6",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.5.0",
    "@next/eslint-plugin-next": "^16.0.10",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-themes": "^10.3.6",
    "@storybook/nextjs-vite": "^10.3.6",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "eslint": "^10.0.1",
    "eslint-config-next": "^16.0.10",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-perfectionist": "^5.0.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "postcss": "^8.5.4",
    "postcss-preset-mantine": "^1.17.0",
    "postcss-simple-vars": "^7.0.1",
    "storybook": "^10.3.6",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.49.0"
  }
}
