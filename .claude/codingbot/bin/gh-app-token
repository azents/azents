#!/usr/bin/env bash
# Return a GitHub App installation token or JWT.
# Read app credentials from config.yaml and exchange a JWT for an installation token.
# Cache the token so every invocation does not request a new token.
#
# Usage:
#   gh-app-token          # Return an installation token (default)
#   gh-app-token --jwt    # Return a JWT for app-level API calls
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Check the --jwt flag.
if [[ "${1:-}" == "--jwt" ]]; then
    JWT_ONLY=true
else
    JWT_ONLY=false
fi

# Locate config.yaml.
# 1) CODINGBOT_CONFIG environment variable
# 2) Main worktree from git worktree list, which also works from worktrees
# 3) Fallback relative to the script location
if [[ -z "${CODINGBOT_CONFIG:-}" ]]; then
    CODINGBOT_CONFIG="$(git config --get codingbot.config 2>/dev/null || true)"
fi
if [[ -z "${CODINGBOT_CONFIG:-}" ]]; then
    MAIN_WORKTREE="$(git worktree list --porcelain 2>/dev/null | head -1 | sed 's/^worktree //')"
    if [[ -n "$MAIN_WORKTREE" && -f "$MAIN_WORKTREE/python/apps/codingbot/config.yaml" ]]; then
        CODINGBOT_CONFIG="$MAIN_WORKTREE/python/apps/codingbot/config.yaml"
    else
        CODINGBOT_CONFIG="config.yaml"
    fi
fi
export CODINGBOT_CONFIG

infer_repo_from_url() {
    local url="$1"
    local slug=""

    case "$url" in
        https://github.com/*)
            slug="${url#https://github.com/}"
            ;;
        https://*@github.com/*)
            slug="${url#*github.com/}"
            ;;
        git@github.com:*)
            slug="${url#git@github.com:}"
            ;;
        ssh://git@github.com/*)
            slug="${url#ssh://git@github.com/}"
            ;;
    esac

    slug="${slug%.git}"
    slug="${slug%/}"
    if [[ "$slug" == */* ]]; then
        printf '%s\n' "$slug"
    fi
}

# If REPO is not set, infer the repo slug from session settings or current origin.
if [[ -z "${REPO:-}" ]]; then
    REPO="$(git config --get codingbot.repo 2>/dev/null || true)"
fi
if [[ -z "${REPO:-}" ]]; then
    ORIGIN_URL="$(git remote get-url origin 2>/dev/null || true)"
    if [[ -n "$ORIGIN_URL" ]]; then
        REPO="$(infer_repo_from_url "$ORIGIN_URL")"
    fi
fi
export REPO

# Parse config.yaml with Python.
# New schema: github_app.installation_ids = {slug: id} (dict)
# Legacy schema: github_app.installation_id = id (int) is also supported.
# Select the installation from REPO environment variable, session settings, then origin remote.
read -r APP_ID PRIVATE_KEY_PATH INSTALLATION_ID <<< "$(python3 -c "
import os
import yaml
with open('$CODINGBOT_CONFIG') as f:
    c = yaml.safe_load(f)
ga = c['github_app']
inst_id = None
if 'installation_id' in ga:
    inst_id = ga['installation_id']
elif 'installation_ids' in ga:
    ids = ga['installation_ids']
    repo = os.environ.get('REPO')
    if repo and repo in ids:
        inst_id = ids[repo]
    elif repo:
        by_lower = {str(k).lower(): v for k, v in ids.items()}
        inst_id = by_lower.get(repo.lower())
        if inst_id is None:
            known = ', '.join(str(k) for k in ids)
            raise SystemExit(f'No installation id configured for repo {repo!r}. Known repos: {known}')
    elif ids:
        inst_id = next(iter(ids.values()))
if inst_id is None:
    raise SystemExit('No installation id found in config')
print(ga['app_id'], ga['private_key_path'], inst_id)
")"

# Generate a JWT.
generate_jwt() {
    python3 -c "
import time, jwt

with open('$PRIVATE_KEY_PATH') as f:
    private_key = f.read()

now = int(time.time())
payload = {'iat': now - 60, 'exp': now + (9 * 60), 'iss': '$APP_ID'}
print(jwt.encode(payload, private_key, algorithm='RS256'))
"
}

# In --jwt mode, return only the JWT and exit.
if [[ "$JWT_ONLY" == "true" ]]; then
    generate_jwt
    exit 0
fi

# Cache file.
CACHE_DIR="${HOME}/.cache"
mkdir -p "$CACHE_DIR"
CACHE_FILE="$CACHE_DIR/gh-app-installation-token-${INSTALLATION_ID}.json"

# Check the cache.
if [[ -f "$CACHE_FILE" ]]; then
    EXPIRES_AT=$(python3 -c "
import json, sys
with open('$CACHE_FILE') as f:
    data = json.load(f)
print(data.get('expires_at', ''))
")
    NOW=$(date -u +%Y-%m-%dT%H:%M:%SZ)
    if [[ "$EXPIRES_AT" > "$NOW" ]]; then
        python3 -c "
import json
with open('$CACHE_FILE') as f:
    print(json.load(f)['token'])
"
        exit 0
    fi
fi

# Generate a JWT and exchange it for an installation token.
python3 -c "
import json, time, jwt, httpx, sys

with open('$PRIVATE_KEY_PATH') as f:
    private_key = f.read()

now = int(time.time())
payload = {'iat': now - 60, 'exp': now + (9 * 60), 'iss': '$APP_ID'}
token_jwt = jwt.encode(payload, private_key, algorithm='RS256')

resp = httpx.post(
    'https://api.github.com/app/installations/$INSTALLATION_ID/access_tokens',
    headers={'Authorization': f'Bearer {token_jwt}', 'Accept': 'application/vnd.github+json'},
)
resp.raise_for_status()
data = resp.json()

with open('$CACHE_FILE', 'w') as f:
    json.dump({'token': data['token'], 'expires_at': data['expires_at']}, f)

print(data['token'])
"
