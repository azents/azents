#!/usr/bin/env bash
# Bot identityлҘј лҸҷм Ғ м¶”м¶ңн•ҳм—¬ worktree лЎңм»¬ git configм—җ м„Өм •н•ңлӢӨ.
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Bot identity лҸҷм Ғ м¶”м¶ң (/app endpointлҠ” JWT Bearer мқёмҰқ н•„мҡ”)
JWT=$("$SCRIPT_DIR/gh-app-token" --jwt)
APP_JSON=$(curl -sS --fail -H "Authorization: Bearer $JWT" -H "Accept: application/vnd.github+json" https://api.github.com/app)
APP_SLUG=$(echo "$APP_JSON" | python3 -c "import json,sys; print(json.load(sys.stdin)['slug'])")
APP_ID=$(echo "$APP_JSON" | python3 -c "import json,sys; print(json.load(sys.stdin)['id'])")
BOT_NAME="${APP_SLUG}[bot]"
BOT_EMAIL="${APP_ID}+${APP_SLUG}[bot]@users.noreply.github.com"

# worktree лЎңм»¬ git configм—җл§Ң м Ғмҡ©
git config user.name "$BOT_NAME"
git config user.email "$BOT_EMAIL"

# session repo кё°ліёк°’кіј credential helper лҘј worktree лЎңм»¬ git config м—җ м ҖмһҘн•ңлӢӨ.
REPO_SLUG="${REPO:-}"
CONFIG_PATH="${CODINGBOT_CONFIG:-}"
if [[ -n "$REPO_SLUG" ]]; then
    git config codingbot.repo "$REPO_SLUG"
fi
if [[ -n "$CONFIG_PATH" ]]; then
    git config codingbot.config "$CONFIG_PATH"
fi
git config credential.helper "!f() { echo \"protocol=https\"; echo \"host=github.com\"; echo \"username=x-access-token\"; echo \"password=\$(REPO=\"$REPO_SLUG\" CODINGBOT_CONFIG=\"$CONFIG_PATH\" $SCRIPT_DIR/gh-app-token)\"; }; f"
